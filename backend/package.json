{
  "name": "eat-picker-backend",
  "version": "1.0.0",
  "description": "Eat Picker restaurant recommendation API",
  "author": "Wong Ken",
  "main": "dist/server.js",
  "type": "commonjs",
  "scripts": {
    "dev:old": "nodemon --exec ts-node src/server.ts",
    "dev": "nodemon --exec \"ts-node -r tsconfig-paths/register src/server.ts\"",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "build": "npm run db:prod && tsc",
    "db:prod": "npm run db:migrate:prod && npm run db:generate",
    "db:migrate:prod": "prisma migrate deploy --schema=./prisma/schema",
    "db:dev": "npm run db:migrate && npm run db:generate",
    "db:migrate": "prisma migrate dev --schema=./prisma/schema",
    "db:generate": "prisma generate --schema=./prisma/schema",
    "db:migrate:create": "prisma migrate dev --create-only --schema=./prisma/schema",
    "db:migrate:apply": "prisma migrate dev --apply --schema=./prisma/schema",
    "db:studio": "prisma studio --schema=./prisma/schema",
    "db:push": "prisma db push --schema=./prisma/schema",
    "db:status": "prisma migrate status --schema=./prisma/schema",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "prepare": "husky",
    "test": "jest"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "morgan": "^1.10.1",
    "pg": "^8.19.0",
    "prisma": "^5.22.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.0",
    "@types/jest": "^30.0.0",
    "@types/morgan": "^1.9.10",
    "@types/node": "^20.19.35",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.3.2",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
