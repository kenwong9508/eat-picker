{
  "ts-node": {
    "files": true
  },
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "outDir": "./dist",
    "baseUrl": "./src",
    "paths": {
      "$config/*": ["config/*"],
      "$logger": ["utils/logger"],
      "$utils/*": ["utils/*"],
      "$routes/*": ["routes/*"]
    },
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true
  }
}
